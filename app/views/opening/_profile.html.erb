<div class="border-b bg-gray-50 border-gray-200 py-4 lg:pl-8 w-full lg:shrink-0 lg:border-b-0 border-r xl:pl-6">
  <!-- Left column area -->
  <!-- drawer component -->
  <div id="readUserDrawerAdvanced" class="pr-4 bg-gray-50 dark:bg-gray-800">
    <div class="flex items-center mb-4 sm:mb-5">
      <div>
        <h4 id="drawer-label" class="flex items-center mb-1 text-lg font-semibold leading-none text-gray-900 dark:text-white">
          <%= opening.title %>

          <% if policy(:opening).edit? %>
            <a href="<%= edit_opening_path(opening) %>" data-tooltip-target="tooltip-edit" class="p-1 ml-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"><%= svg_icon("profile-edit", class_name: "w-5 h-5") %><span class="sr-only">Edit Opening</span></a>
            <div id="tooltip-edit" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
              Edit Opening
              <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
          <% end %>

          <a
            href="<%= show_public_openings_path(opening) %>"
            target="_blank"
            data-tooltip-target="tooltip-view"
            class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
          >
            <%= svg_icon("opening-external", class_name: "w-5 h-5 text-gray-800 dark:text-white") %>
          </a>

          <div id="tooltip-view" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
            View Opening
            <div class="tooltip-arrow" data-popper-arrow></div>
          </div>
        </h4>

        <% unless opening.location.nil? %>
          <div class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
            <%= svg_icon("location-pin", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>

            <p class="text-gray-900 text-sm dark:text-gray-400"><%= opening.location %></p>
          </div>
        <% end %>
      </div>
    </div>

    <% unless opening.role.blank? %>
      <dt class="mb-2 mt-5 font-semibold text-sm leading-none text-gray-900 dark:text-white">Primary Skill</dt>
      <dd class="mb-4 sm:mb-5">
        <span class="bg-primary-100 text-primary-800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm dark:bg-primary-200 dark:text-primary-800"><%= opening.role.title %></span>
      </dd>
    <% end %>

    <div class="mb-24">
      <dt class="mb-2 font-semibold leading-none text-gray-900 text-sm dark:text-white">Other Details</dt>

      <dd class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
        <%= svg_icon("user-round", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>
        <p class="text-gray-900 text-sm dark:text-gray-400">Owner: <%= opening.owner.name %></p>
      </dd>

      <dd class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
        <%= svg_icon("clock", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>
        <p class="text-gray-900 text-sm dark:text-gray-400">Created On: <%= display_date(opening.created_at) %></p>
      </dd>

      <dd class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
        <%= svg_icon("clock", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>
        <p class="text-gray-900 text-sm dark:text-gray-400">Updated On: <%= display_date(opening.updated_at) %></p>
      </dd>
    </div>
  </div>
</div>
