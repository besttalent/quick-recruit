
<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell">
      <%= render partial: "opening/profile", locals: { opening: @opening } %>
    </div>
    <div class="flex-1">
      
      <%= render partial: "opening/nav", locals: { opening: @opening } %>
      <div class="p-6 text-sm">
        <%= @opening.description %>
      </div>
    </div>
    <div class="sidebar-panel">
      
      <div>
        <h5 class="panel-title">Edit Job Description </h5>
        <p class="text-muted-sm-spaced">Job Descriptions are open to public and can also be sent to candidates via emails.</p>
        <div class="flex space-x-2">
          <a type="button" href="<%= edit_opening_description_path(@opening, @opening) %>"
                class="btn-primary">
            Edit Job Description
          </a>
          <a type="button" target="_blank" href="<%= show_public_openings_path(@opening) %>"
                class="btn-secondary">
            View
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
