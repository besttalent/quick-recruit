<nav class="bg-gray-800">
  <div class="nav-shell-max">
    <div class="nav-shell-row">
      <div class="nav-mobile-toggle"></div>

      <div class="nav-shell-main">
        <div class="nav-brand-wrap"><a href="/"><h1 class="nav-brand-text">Quick Recruit</h1>        </a></div>
        <div class="nav-user-block">
          <div class="flex space-x-1">
            
            <a href="<%= members_path %>" class="<%= current_page?(members_path) ? "nav-item-selected" : "nav-item-unselected" %>">Team</a>
            <a href="<%= candidates_path %>" class="<%= current_page?(candidates_path) ? "nav-item-selected" : "nav-item-unselected" %>">Candidates</a>
            <a href="<%= pipeline_candidates_path %>" class="<%= current_page?(pipeline_candidates_path) ? "nav-item-selected" : "nav-item-unselected" %>">Pipeline</a>
            <a href="<%= campaigns_path(active: true) %>" class="<%= current_page?(campaigns_path) ? "nav-item-selected" : "nav-item-unselected" %>">Sprints</a>
            <a href="<%= recycle_path %>" class="<%= current_page?(recycle_path) ? "nav-item-selected" : "nav-item-unselected" %>">Recycle</a>
            <a href="<%= openings_path(active: true) %>" class="<%= current_page?(openings_path) ? "nav-item-selected" : "nav-item-unselected" %>">Openings</a>
            <a href="<%= reports_path %>" class="<%= current_page?(reports_path) ? "nav-item-selected" : "nav-item-unselected" %>">Reports</a>
          </div>
        </div>
      </div>

      <div
        class="nav-search-wrap"
        data-behavior="autocomplete"
        data-controller="search"
        data-search-url-value="/search/candidates"
      >
        <div class="nav-dropdown-anchor">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              
              <%= svg_icon("search", class_name: "w-5 h-5 text-gray-400") %>
            </div>
            <input
              id="search"
              name="search"
              class="nav-search-input"
              placeholder="Search Candidates"
              type="search"
              data-search-target="input"
              autocomplete="off"
              spellcheck="false"
            >
          </div>
          <div class="relative">
            <div
              class="nav-user-menu"
              role="menu"
              aria-orientation="vertical"
              aria-labelledby="options-menu"
            >
              <ul data-search-target="results" hidden></ul>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-actions">
        <a href="/candidates/new" class="nav-notification-button">
          <span class="overlay-hitbox"></span>
          <span class="sr-only">View notifications</span>
          <%= svg_icon("plus", class_name: "h-6 w-6") %>
        </a>

        
        <div class="relative ml-3">
          <div>
            <button
              type="button"
              class="nav-user-button"
              id="user-menu-button"
              aria-expanded="false"
              aria-haspopup="true"
              data-dropdown-toggle="user-dropdown"
              data-dropdown-placement="bottom"
            >
              <span class="overlay-hitbox"></span>
              <span class="sr-only">Open user menu</span>
              <%= display_small_avatar(current_user) %>
            </button>
          </div>
          <div
            id="user-dropdown"
            class="nav-user-menu-items"
            role="menu"
            aria-orientation="vertical"
            aria-labelledby="user-menu-button"
            tabindex="-1"
          >
            <div class="px-4 py-3"><span class="nav-user-name"><%= current_user.name %></span><span class="nav-user-email"><%= current_user.email %></span></div>

            <ul class="py-2" aria-labelledby="user-menu-button">
              <li><a href="/account/roles" class="dropdown-item">Account Settings</a></li>
              <li><a href="/settings/profile" class="dropdown-item">Personal Settings</a></li>
              <li><a href="/settings/import" class="dropdown-item">Import Candidates</a></li>
            </ul>

            <ul class="py-2" aria-labelledby="user-menu-button">
              <li><a href="https://release.quicklabs.in/quick-recruit/changelogs" target="_blank" class="dropdown-item">Change Logs</a></li>
              <li><a href="https://release.quicklabs.in/quick-recruit/roadmap" target="_blank" class="dropdown-item">Feature Roadmap</a></li>
            </ul>

            <div class="py-1"><%= button_to "Sign Out", session_path, method: :delete, class: "w-full text-left block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white cursor-pointer" %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
