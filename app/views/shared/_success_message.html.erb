
<% if !message.blank? %>
  <div
    class="p-4 rounded-xs bg-green-50"
    x-data="{open: true}"
    x-show="open"
    x-init="setTimeout(function(){open = false; }, 2000);"
  >
    <div class="flex">
      <div class="flex-shrink-0">
        
        <%= svg_icon("check-circle", class_name: "w-5 h-5 text-green-400") %>
      </div>

      <div class="ml-3">
        <p class="text-sm font-medium text-green-800">
          <%= message %>
        </p>
      </div>

      <div class="hidden pl-3 ml-auto">
        <div class="-mx-1.5 -my-1.5">
          <button class="inline-flex bg-green-50 rounded-xs p-1.5 text-green-500 hover:bg-green-100 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-offset-green-50 focus:ring-green-600">
            <span class="sr-only">Dismiss</span>
            
            <%= svg_icon("x-mark", class_name: "w-5 h-5") %>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
