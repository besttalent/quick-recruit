<div id="openings" class="mx-auto max-w-screen-xl px-4 py-10 sm:px-6 lg:px-8 lg:py-8 2xl:max-w-screen-2xl">
  <div class="mx-auto max-w-screen-md text-center">
    <div class="w-24 mb-4 mx-auto">
      <a href="https://www.crownstack.com"><%= svg_icon("crownstack-logo", class_name: "w-24") %></a>
    </div>

    <h2 class="mb-4 text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white">Open Positions</h2>

    <p class="mb-8 text-gray-800 dark:text-gray-400 sm:text-xl md:text-lg lg:mb-8">Check all of our current open positions. We are looking for folks who can raise the bar.</p>
  </div>

  
  <div class="grid gap-4 sm:grid-cols-2 sm:gap-6 md:grid-cols-3 xl:grid-cols-4">
    <% @openings.each do |opening| %>
      <a class="group flex flex-col rounded-sm border border-gray-200 bg-white shadow-xs transition hover:shadow-md dark:border-gray-800 dark:bg-slate-900" href="<%= "https://recruit.quicklabs.in/public/openings/" + opening.first.to_s %>" target="_blank">
        <div class="p-4 md:p-5">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-gray-800 group-hover:text-gray-600 dark:text-gray-200 dark:group-hover:text-gray-400"><%= opening.second %></h3>
              <p class="text-sm text-gray-500">Full Time, Noida Location</p>
            </div>

            <div class="pl-3">
              <%= svg_icon("chevron-right", class_name: "h-3.5 w-3.5 text-gray-500") %>
            </div>
          </div>
        </div>
      </a>
    <% end %>
  </div>

  <div class="p-4 flex flex-col items-start gap-x-8 gap-y-6 rounded-sm mt-8 ring-1 bg-gray-100 ring-gray-900/10 lg:col-span-2 lg:flex-row lg:items-center">
    <div class="lg:min-w-0 lg:flex-1">
      <h3 class="font-semibold text-gray-800 group-hover:text-gray-600 dark:text-gray-200 dark:group-hover:text-gray-400">Do not see a relevant job opening?</h3>
      <p class="mt-1 text-sm text-gray-500">If you do not see an job opening which is relevant to you, you can still get in touch with us as we are always looking for bright people.</p>
    </div>

    <a href="<%= "/public/openings/apply" %>" class="justify-center rounded-sm bg-red-600 px-4 py-3 text-sm font-semibold text-white shadow-xs hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600">Contact Us <span aria-hidden="true">→</span></a>
  </div>

  
</div>
