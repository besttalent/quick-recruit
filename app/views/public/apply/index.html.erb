<section class="page-surface">
  <div class="page-form-container">
    <div class="w-24 mb-4">
      <a href="/public/openings"><%= image_tag current_account.logo.variant(resize_to_limit: [96, 96]), class: "w-24 h-24 rounded-full object-cover", alt: "#{current_account.company_name} logo" if current_account.logo.attached? %></a>
    </div>

    <div>
      <h1 class="text-2xl font-bold dark:text-white">
        Work At
      </h1>

      <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">
        Please tell us about your contact details and we will be in touch.
      </p>
    </div>

    <%= tailwind_form_with(model: @candidate, id: dom_id(@candidate), url: public_apply_path) do |form| %>
      <%= render "shared/error_messages", resource: @candidate %>
      <%= render "shared/form_messages", resource: @candidate, message: local_assigns[:message] %>

      <div class="form-grid-simple">
        <div class="sm:col-span-2">
          <div class="py-4">
            <h2 class="text-lg mb-1 font-semibold leading-none text-gray-900 dark:text-white">Upload Resume</h2>
            <label class="block mb-2 text-sm text-gray-500 dark:text-white" for="file_input">Please upload PDF resume file only. Other file types will result in automatic rejection by our ATS. PDF file should be less than 5 MB.</label>

            <div class="items-center w-full sm:flex">
              <div class="w-full"><%= form.file_field :resume, accept: "application/pdf", required: true, id: "file_input" %></div>
            </div>
          </div>

          <h2 class="mt-8 text-xl font-semibold leading-none text-gray-900 dark:text-white">Personal Information</h2>
        </div>

        <div><%= form.text_field :first_name, "First Name", required: true, placeholder: "John" %></div>

        <div class="w-full"><%= form.text_field :last_name, "Last Name", required: true, placeholder: "Doe" %></div>

        <div><%= form.text_field :email, "Email", required: true, placeholder: "name@domain.com" %></div>

        <div><%= form.text_field :phone, "Phone", required: true, placeholder: "9876543210", minlength: 10, maxlength: 10, pattern: "[0-9]{10}" %></div>

        <div><%= form.text_field :location, "Current City", required: true, placeholder: "Noida" %></div>

        <div><%= form.text_field :birth_year, "Birth Year", required: true, placeholder: "1989", minlength: 4, maxlength: 4, pattern: "[0-9]{4}" %></div>

        <%= form.hidden_field :opening_id, value: params[:opening_id] %>

        <div class="sm:col-span-2 mb-4"><%= form.text_area :biography, "Tell us about yourself", placeholder: "Some personal and professional details about yourself..", style: "height:120px" %></div>
      </div>

      <h2 class="page-section-title">Professional Information</h2>

      <div class="form-grid-2">
        <div><%= form.text_field :current_title, "Current Job Title", required: true, placeholder: "Senior Software Engineer" %></div>

        <div><%= form.text_field :current_company, "Current Employer", required: true, placeholder: "Current Company Name" %></div>

        <div><%= form.text_field :current_ctc, "Current CTC in LPA", required: true, placeholder: "12.5" %></div>

        <div><%= form.text_field :expected_ctc, "Expected CTC in LPA", required: true, placeholder: "14.5" %></div>

        <div><%= form.text_field :experience, "Experience in Years", required: true, placeholder: "5.2" %></div>

        <div><%= form.text_field :notice_period, "Notice Period in Days", required: true, placeholder: "30" %></div>

        <div><%= form.text_field :highest_qualification, "Highest Education Qualification", required: true, placeholder: "B.Tech" %></div>

        <div><%= form.text_field :linkedin, "Linkedin Profile URL", placeholder: "https://www.linkedin.com/in/profileId", required: true %></div>
      </div>

      <%= form.submit "Submit Application", class: "btn-primary", data: { disable_with: "Please wait..." } %>
      <%= link_to "Cancel", public_openings_path, class: "btn-secondary" %>
    <% end %>
  </div>
</section>
