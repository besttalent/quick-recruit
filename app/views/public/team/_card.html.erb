<section class="max-w-sm w-full border border-gray-200 rounded-xs shadow-xs p-4 md:p-6">
  <div class="flex flex-col items-center gap-4 text-neutral-700">
    <%= display_normal_avatar(member) %>

    <div class="flex flex-col items-center gap-1">
      <h1 class="font-semibold text-xl"><%= member.name %></h1>
      <span class="text-sm"><%= member.current_title %></span>
    </div>

    <p class="text-center text-sm"><%= member.biography %></p>

    <% if member.booking_url.present? %>
      <div class="flex gap-2">
        <a class="w-full btn-primary" target="_blank" href="<%= member.booking_url %>">Book an appointment</a>

        <button
          type="button"
          class="flex items-center justify-center flex-shrink-0 p-2 rounded-sm border border-gray-300 bg-white hover:bg-gray-50"
          aria-label="Copy calendar link"
          onclick="const btn=this;const icon=btn.querySelector('.copy-icon');const check=btn.querySelector('.copied-icon');navigator.clipboard.writeText('<%= j member.booking_url %>');icon.style.display='none';check.style.display='inline';setTimeout(()=>{icon.style.display='inline';check.style.display='none';},1200);"
        >
          <%= svg_icon("copy-duplicate", class_name: "copy-icon h-5 w-5 text-gray-500") %>
          <%= svg_icon("check-mark", class_name: "copied-icon h-5 w-5 text-green-500") %>
        </button>
      </div>
    <% end %>

    <div class="flex flex-row gap-2">
      <% if member.github.present? %>
        <a aria-label="Link to GreatFrontEnd's GitHub profile" href="<%= member.github %>"><%= svg_icon("github-logo", class_name: "h-6 w-6 text-indigo-700") %></a>
      <% end %>

      <% if member.linkedin.present? %>
        <a aria-label="Link to GreatFrontEnd's Linkedin profile" href="<%= member.linkedin %>"><%= svg_icon("linkedin-logo", class_name: "h-6 w-6 text-indigo-700") %></a>
      <% end %>

      <% if member.twitter.present? %>
        <a aria-label="Link to GreatFrontEnd's Twitter profile" href="<%= member.twitter %>"><%= svg_icon("x-logo", class_name: "h-6 w-6 text-indigo-700") %></a>
      <% end %>
    </div>
  </div>
</section>
