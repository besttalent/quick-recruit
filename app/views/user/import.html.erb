<section class="page-surface">
  <div class="form-page-container">
    <%= form_tag import_csv_path, method: :post, multipart: true do %>
      <div class="form-grid-simple">
        <div class="sm:col-span-2">
          <div class="py-4">
            <h2 class="text-lg mb-1 font-semibold leading-none text-gray-900 dark:text-white">
              Import CSV File
            </h2>

            <label class="block mb-2 text-sm text-gray-500 dark:text-white" for="file_input">Please upload CSV files only. Other file types will result in automatic rejection by our ATS. File should be less than 5 MB.</label>

            <div class="items-center w-full sm:flex">
              <div class="w-full"><%= file_field_tag :file, accept: ".csv", id: "file_input" %></div>
            </div>
          </div>

          <div>
            <label for="import_bucket" class="form-field-label-inline-spaced">
              Select which bucket to assign candidates to
              <button
                type="button"
                data-tooltip-target="tooltip-user-bucket"
                data-tooltip-style="dark"
                class="ml-1"
              >
                <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>
                <span class="sr-only">Show information</span>
              </button>
              <%= tooltip_component(id: "tooltip-user-bucket", text: "In which bucket you want to these candidates after import.", class_name: "max-w-sm font-normal") %>
            </label>

            <%= select_tag :bucket, options_for_select(Candidate.buckets.map { |k, v| [k.humanize.capitalize, k] }), class: "form-text-field", :name => "import[bucket]", id: "import_bucket" %>
          </div>

          <div class="sm:col-span-2 mt-4 mb-4">
            <label for="import_opening_id" class="form-field-label-inline-spaced">
              Associate candidates with Job Opening
              <button
                type="button"
                data-tooltip-target="tooltip-user-opening"
                data-tooltip-style="dark"
                class="ml-1"
              >
                <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>
                <span class="sr-only">Show information</span>
              </button>
              <%= tooltip_component(id: "tooltip-user-opening", text: "With which job opening you would like to Associate these candidates.", class_name: "max-w-sm font-normal") %>
            </label>

            <%= select_tag :opening_id, options_for_select(Opening.all.order(:title).map { |k, v| [k.title, k.id] }), class: "form-text-field", :name => "import[opening_id]", id: "import_opening_id" %>
          </div>

          <div class="sm:col-span-2 mt-4 mb-4">
            <label for="import_style" class="form-field-label-inline-spaced">
              Select type of import
              <button
                type="button"
                data-tooltip-target="tooltip-import-nature"
                data-tooltip-style="dark"
                class="ml-1"
              >
                <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>
                <span class="sr-only">Show information</span>
              </button>
              <%= tooltip_component(id: "tooltip-import-nature", text: "Please select what type of data you are importing.", class_name: "max-w-sm font-normal") %>
            </label>

            <%= select_tag :opening_id, options_for_select([["Import Naukri Outbound Leads", "ImportNaukriOutboundLeads"], ["Import Naukri Inbound Leads", "ImportNaukriInboundLeads"]]), class: "form-text-field", :name => "import[style]", id: "import_style" %>
          </div>

          <%= submit_tag "Import", class: "btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
