<main class="settings-shell">
  <div class="settings-grid">
    <%= render "shared/settings_menu" %>
    <main class="settings-content">
      <div class="mt-6 flex-grow lg:mt-0 lg:ml-6 lg:flex-shrink-0 lg:flex-grow-0">
        <%= turbo_frame_tag "profile_form" do %>
          <%= render "user/forms/profile", user: @user %>
        <% end %>
      </div>
    </main>

    <div class="flex"><%= render "user/forms/avatar", user: @user %></div>
  </div>
</main>
