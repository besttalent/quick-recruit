<%= turbo_frame_tag dom_id(resource) do %>
  <%= form_with(model: resource, id: dom_id(resource), url: update_path) do |form| %>
    <% if local_assigns[:messages] && defined?(messages) && !messages.nil? %>
      <% messages.each do |message| %>
        <p class="mt-2 text-sm text-red-600"><%= message %></p>
      <% end %>
    <% end %>

    <li class="flex w-full py-4 border-b border-gray-200">
      <div class="w-full"><%= form.text_field :title, class: "form-text-field", autocomplete: "off" %></div>
      <div class="flex"><%= form.submit "Save", class: "btn-primary ml-3" %></div>
    </li>
  <% end %>
<% end %>
