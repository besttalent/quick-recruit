<div class="mt-6 flex-grow lg:mt-0 lg:flex-shrink-0 lg:flex-grow-0" id="<%= dom_id(account, :logo) %>">
  <%= form_with(model: account, id: "company_logo_upload", url: logo_account_account_path, remote: true, method: :patch, html: { multipart: true }, local: true) do |f| %>
    <label for="desktop-company-logo" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Company Logo</label>

    <div class="mt-1 lg:hidden">
      <div class="flex items-center">
        <div class="inline-block h-24 w-24 flex-shrink-0 overflow-hidden rounded-full" aria-hidden="true">
          <% if account.logo.attached? %>
            <%= image_tag account.logo.variant(resize_to_limit: [160, 160]), class: "w-24 h-24 rounded-full object-cover", alt: "Company logo" %>
          <% else %>
            <%= image_tag "male-placeholder.png", class: "w-24 h-24 rounded-full object-cover", alt: "Placeholder logo" %>
          <% end %>
        </div>

        <div class="ml-5 rounded-xs shadow-xs">
          <div class="group relative flex items-center justify-center rounded-xs border border-gray-300 py-2 px-3 focus-within:ring-2 focus-within:ring-sky-500 focus-within:ring-offset-2 hover:bg-gray-50">
            <span class="pointer-events-none relative text-sm font-medium leading-4 text-gray-700"><span>Change</span><span class="sr-only">company logo</span></span>
          </div>
        </div>
      </div>
    </div>

    <div class="relative hidden overflow-hidden rounded-full lg:block w-24 h-24">
      <% if account.logo.attached? %>
        <%= image_tag account.logo.variant(resize_to_limit: [160, 160]), class: "w-24 h-24 rounded-full object-cover", alt: "Company logo" %>
      <% else %>
        <%= image_tag "male-placeholder.png", class: "w-24 h-24 rounded-full object-cover", alt: "Placeholder logo" %>
      <% end %>

      <label for="desktop-company-logo" class="absolute inset-0 flex h-full w-full items-center justify-center bg-black bg-opacity-75 text-sm font-medium text-white opacity-0 focus-within:opacity-100 hover:opacity-100">
        <span>Change</span>
        <span class="sr-only">company logo</span>

        <input
          type="file"
          id="desktop-company-logo"
          name="account[logo]"
          accept="image/png,image/jpeg"
          class="absolute inset-0 h-full w-full cursor-pointer rounded-xs border-gray-300 opacity-0"
          onchange="document.getElementById('company_logo_upload').submit();"
        >
      </label>
    </div>
  <% end %>

  <% if account.logo.attached? %>
    <div class="mt-6 flex justify-center">
      <%= styled_delete_button(
            logo_account_account_path,
            "btn-inline-delete text-red-600",
            title: "Remove Logo",
            message: "Are you sure you want to delete company logo?"
          ) %>
    </div>
  <% end %>
</div>
