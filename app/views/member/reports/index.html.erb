
<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell">
      <%= render partial: "member/profile", locals: { member: @member } %>
    </div>
    <div class="flex-1">
      
      <%= render partial: "member/nav", locals: { member: @member } %>
      <div class="table-wrap">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <thead class="table-head-muted">
            <tr>
              <th scope="col w-full" class="px-4 py-2">
                Title
              </th>
              <th scope="col" class="px-4 py-2">
                Submitted By
              </th>
              <th scope="col" class="px-4 py-2">
                Created At
              </th>
              <th scope="col" class="px-4 py-2">
                Status
              </th>
              <th scope="col" class="px-4 py-2">
                Action
              </th>
            </tr>
          </thead>
          <tbody>
            <%= render @reports %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="sidebar-panel">
      
      <div>
        <h5 class="panel-title">Submit New Report</h5>
        <p class="text-muted-sm-spaced">You can submit a daily, weekly, quarterly or yearly report for future reference.</p>
        <a href="<%= new_member_report_path(@member) %>" class="btn-primary">
          Submit Report
        </a>
      </div>
    </div>
  </div>
</div>
