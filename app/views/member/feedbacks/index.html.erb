

<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell"><%= render partial: "member/profile", locals: { member: @member } %></div>

    <div class="flex-1">
      
      <%= render partial: "member/nav", locals: { member: @member } %>
      <div class="table-wrap">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <thead class="table-head-muted">
            <tr>
              <th scope="col w-full" class="px-4 py-2">
                Title
              </th>
              <th scope="col" class="px-4 py-2">
                Submitted By
              </th>
              <th scope="col" class="px-4 py-2">
                Created At
              </th>
              <th scope="col" class="px-4 py-2">
                Status
              </th>
            </tr>
          </thead>
          <tbody><%= render @feedbacks %></tbody>
        </table>
      </div>
    </div>

    <div class="sidebar-panel">
      
      <% if current_user.admin_or_recruiter_admin? %>
        <div>
          <h5 class="panel-title">Submit New Feedback</h5>

          <p class="text-muted-sm-spaced">Submit a new feedback which can help your team members.</p>
          <a href="<%= new_member_feedback_path(@member) %>" class="btn-primary">Submit Feedback</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
