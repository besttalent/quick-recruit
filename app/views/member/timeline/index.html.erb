
<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell">
      <%= render partial: "member/profile", locals: { member: @member } %>
    </div>
    <div class="flex-1">
      
      <%= render partial: "member/nav", locals: { member: @member } %>
      <div class="px-0 lg:px-6 py-6">
        <ol class="relative border-s border-gray-200 dark:border-gray-700">
          <% unless @events.nil? %>
            <% @events.each do |event| %>
              <%= render partial: "member/timeline/activity", locals: { event: event } %>
            <% end %>
          <% end %>
        </ol>
      </div>
    </div>
    <div class="shrink-0 border-t border-gray-200 px-4 py-6 sm:px-6 lg:w-80 lg:border-l lg:border-t-0 lg:pr-8 xl:pr-6">
      
    </div>
  </div>
</div>
