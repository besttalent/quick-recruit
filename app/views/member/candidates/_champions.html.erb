<tr class="group hover-list-row">
  <th scope="row" class="table-cell-strong">
    <div class="inline-link-row">
      <a href="<%= candidate_timeline_path(candidate) %>"><%= candidate.name %></a>

      <a href="<%= candidate_timeline_path(candidate) %>" class="hover-reveal-link"><%= svg_icon("candidate-eye", class_name: "w-4 h-4 text-gray-800 dark:text-white") %></a>
    </div>
  </th>

  <td class="px-4 py-2"><%= candidate.owner.name %></td>
  <td class="px-4 py-2"><%= display_date(candidate.bucket_updated_on) %></td>
  <td class="px-4 py-2"><span class="bg--100 text--800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm <%= status_color(candidate.status) %> <%= status_color(candidate.status) %>"><%= candidate.status.humanize.titleize %></span></td>
  <td class="px-4 py-2"><span class="bg-primary-100 text-primary-800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm"><%= candidate.bucket.humanize %></span></td>
</tr>
