

<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell"><%= render partial: "member/profile", locals: { member: @member } %></div>

    <div class="flex-1">
      
      <%= render partial: "member/nav", locals: { member: @member } %>

      <div class="table-wrap">
        <table class="text-sm text-left text-gray-500 dark:text-gray-400 w-full">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">Champion Name</th>
              <th scope="col" class="table-head-cell">Owner</th>
              <th scope="col" class="table-head-cell">Last Updated On</th>
              <th scope="col" class="table-head-cell">Last known Status</th>
              <th scope="col" class="px-4 py-3">Bucket</th>
            </tr>
          </thead>

          <tbody><%= render partial: "champions", collection: @champions, as: :candidate %></tbody>
        </table>

        <% if @champions.count > 0 %>
          <p class="p-4 text-sm text-gray-500">This list is showing champions only who cleared hiring process in past. To see other candidates, please <span><a href="<%= "/report/candidates?owner_id=" + current_user.id.to_s %>" class="text-blue-600 dark:text-blue-500 hover:underline text-sm font-medium">click here</a></span> .</p>
        <% end %>
      </div>
    </div>

    <div class="sidebar-panel">
      
      <div>
        <h5 class="panel-title">Candidates</h5>

        <p class="text-muted-sm-spaced">Following candidates are associated with you across different buckets.</p>

        <div class="flex flex-col"><%= display_owner_associations(@member) %></div>
      </div>
    </div>
  </div>
</div>
