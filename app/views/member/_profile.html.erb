<div class="border-b bg-gray-50 border-gray-200 py-4 lg:pl-8 w-full xl:shrink-0 xl:border-b-0 xl:border-r xl:pl-6">
  <!-- Left column area -->
  <!-- drawer component -->
  <div id="readUserDrawerAdvanced" class="pr-4 overflow-y-auto h-screen bg-gray-50 dark:bg-gray-800">
    <div class="flex items-center mb-4 sm:mb-5">
      <div>
        <h4 id="drawer-label" class="flex items-center mb-1 text-lg font-semibold leading-none text-gray-900 dark:text-white">
          <%= member.name %>
          <a href="<%= edit_member_path(member) %>" data-tooltip-target="tooltip-edit" class="p-1 ml-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"><%= svg_icon("profile-edit", class_name: "w-5 h-5") %><span class="sr-only">Edit Profile</span></a>
        </h4>

        <%= tooltip_component(id: "tooltip-edit", text: "Edit profile") %>

        <div class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
          <%= svg_icon("email", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>

          <p class="text-gray-900 text-sm dark:text-gray-400"><%= member.email %></p>
        </div>

        <div class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
          <%= svg_icon("phone", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>

          <p class="text-gray-900 text-sm dark:text-gray-400"><%= member.phone %></p>
        </div>

        <div class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
          <%= svg_icon("location-pin", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>

          <p class="text-gray-900 text-sm dark:text-gray-400"><%= member.location %></p>
        </div>
      </div>
    </div>

    <dl>
      <dt class="mb-2 text-sm font-medium leading-none text-gray-900 dark:text-white">Biography</dt>

      <dd class="mb-4 font-light text-gray-900 text-sm sm:mb-5 dark:text-gray-400"><%= member.biography %></dd>

      <%= render partial: "candidate/social", locals: { candidate: member } %>

      <dt class="mb-2 font-semibold text-sm leading-none text-gray-900 dark:text-white">Role</dt>

      <dd class="mb-4 sm:mb-5">
        <span class="bg-primary-100 text-primary-800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm dark:bg-primary-200 dark:text-primary-800"><%= svg_icon("candidate-eye", class_name: "mr-1 w-3 h-3") %><%= member.role.titleize %></span>
      </dd>

      <dt class="mb-2 font-semibold leading-none text-gray-900 text-sm dark:text-white">Professional Details</dt>

      <dd class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
        <%= svg_icon("company-building", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>
        <p class="text-gray-900 text-sm dark:text-gray-400"><%= member.current_company %></p>
      </dd>

      <dd class="flex items-center text-sm font-light text-gray-900 dark:text-gray-400">
        <%= svg_icon("briefcase", class_name: "w-4 h-4 mr-2 text-gray-800 dark:text-white") %>
        <p class="text-gray-900 text-sm dark:text-gray-400"><%= member.current_title %></p>
      </dd>
    </dl>
  </div>
</div>
