<section class="bg-gray-50 dark:bg-gray-900">
  <div class="auth-shell">
    <a href="/" class="auth-brand">
      <img class="w-8 h-8 mr-2" src="/icon-192.png" alt="logo">
      Quick Recruit
    </a>

    <div class="w-full bg-white rounded-xs shadow-sm dark:border md:mt-0 sm:max-w-md xl:p-0 dark:bg-gray-800 dark:border-gray-700">
      <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
        <h1 class="page-heading">
          Sign in to your account
        </h1>

        <form class="space-y-4 md:space-y-6" action="/session" method="POST">
          <div>
            <label for="email" class="form-input-label"> Your email </label>

            <input
              type="email"
              name="email"
              id="email"
              class="form-text-field"
              placeholder="name@company.com"
              autocomplete="email"
              required
            >
          </div>

          <div>
            <label for="password" class="form-input-label"> Password </label>

            <input
              type="password"
              name="password"
              id="password"
              placeholder="••••••••"
              class="form-text-field"
              autocomplete="current-password"
              required
            >
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-start">
              <div class="flex items-center h-5">
                <input
                  id="remember"
                  aria-describedby="remember"
                  type="checkbox"
                  class="checkbox"
                >
              </div>

              <div class="ml-3 text-sm"><label for="remember" class="text-muted-sm"> Remember me </label></div>
            </div>

            <a href="/password_reset/new" class="link"> Forgot password? </a>
          </div>

          <button type="submit" class="w-full btn-primary">Sign in</button>
        </form>
      </div>
    </div>
  </div>
</section>
