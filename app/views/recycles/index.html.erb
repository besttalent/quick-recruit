<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <div class="page-panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Recycle Candidates</h1>
            <p class="text-muted-sm"><span class="font-bold"><%= @recycles.count %></span> candidates need to be recycled.</p>
          </div>

          <%= button_to "Settle & Refresh", recycle_path, class: "btn-primary", data: {
                                                            controller: "confirmation",
                                                            "confirmation-message-value": "Are you sure you want to settle recycled candidates and refresh data again?",
                                                            action: "confirmation#confirm",
                                                          } %>
        </div>

        <% if current_user.admin_or_recruiter_admin? %>
          <div class="flex flex-wrap pt-1 pb-4 dark:border-gray-700 px-4 space-y-3 sm:flex sm:space-y-0 sm:space-x-4">
            <div class="items-center hidden mt-3 mr-4 text-sm font-medium text-gray-900 md:flex dark:text-white">
              Show records only for:
            </div>

            <div class="flex flex-wrap">
              <% @recruiters.each do |recruiter| %>
                <a href="<%= recycle_path(recruiter: recruiter.id) %>">
                  <div class="flex items-center mt-3 mr-4">
                    <% if params[:recruiter].to_i == recruiter.id %>
                      <input
                        id="all-products"
                        type="radio"
                        value=""
                        name="show-only"
                        class="form-radio"
                        checked
                      >
                    <% else %>
                      <input
                        id="all-products"
                        type="radio"
                        value=""
                        name="show-only"
                        class="form-radio"
                      >
                    <% end %>

                    <label for="all-products" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300"><%= recruiter.name %></label>
                  </div>
                </a>
              <% end %>

              <% unless params[:recruiter].nil? %>
                <%= link_to "Show All", recycle_path, class: "underline mt-3 mr-4 link" %>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="sidebar-scroll-x">
          <table class="input-muted">
            <thead class="table-head-muted">
              <tr>
                <th scope="col" class="px-4 py-3">Name</th>
                <th scope="col" class="px-4 py-3">Job Association</th>
                <th scope="col" class="table-head-cell">Owner</th>
                <th scope="col" class="table-head-cell">Added On</th>
                <th scope="col" class="table-head-cell">Duration</th>
                <th scope="col" class="table-head-cell">Bucket</th>
                <th scope="col" class="table-head-cell">Last known Status</th>
              </tr>
            </thead>

            <tbody><%= render partial: "candidate", collection: @recycles, as: :recycle %></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
