<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class="list-divider">
        <div class="panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Hot Candidates</h1>
            <p class="text-muted-sm">Following <span class="font-bold"><%= @candidates.count %></span> candidates are active and looking for job change and should be porcessed as soon as possible.</p>
          </div>

          <a type="button" href="/candidates/new" class="btn-primary">Add new candidate</a>
        </div>
      </div>

      <% if current_user.admin_or_recruiter_admin? %>
        <div class="flex flex-wrap pt-1 pb-4 border-t border-b border-gray-200 dark:border-gray-700 px-4 space-y-3 sm:flex sm:space-y-0 sm:space-x-4">
          <div class="items-center hidden mt-3 mr-4 text-sm font-medium text-gray-900 md:flex dark:text-white">
            Show records only for:
          </div>

          <div class="flex flex-wrap">
            <% @recruiters.each do |recruiter| %>
              <a href="<%= hot_candidates_path(recruiter: recruiter.id) %>">
                <div class="flex items-center mt-3 mr-4">
                  <% if params[:recruiter].to_i == recruiter.id %>
                    <input
                      id="all-products"
                      type="radio"
                      value=""
                      name="show-only"
                      class="form-radio"
                      checked
                    >
                  <% else %>
                    <input
                      id="all-products"
                      type="radio"
                      value=""
                      name="show-only"
                      class="form-radio"
                    >
                  <% end %>

                  <label for="all-products" class="ml-2 text-sm font-medium text-gray-900 dark:text-gray-300"><%= recruiter.name %></label>
                </div>
              </a>
            <% end %>

            <% unless params[:recruiter].nil? %>
              <%= link_to "Show All", hot_candidates_path, class: "underline mt-3 mr-4 link" %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="scroll-x">
        <table class="input-muted">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">Name</th>
              <th scope="col" class="px-4 py-3">Primary Skill</th>
              <th scope="col" class="px-4 py-3">Job Association</th>
              <th scope="col" class="table-head-cell">Owner</th>
              <th scope="col" class="table-head-cell">Added By</th>
              <th scope="col" class="table-head-cell">Added On</th>
            </tr>
          </thead>

          <tbody><%= render partial: "hot", collection: @candidates, as: :candidate %></tbody>
        </table>
      </div>

      <div class="actions-row"><%== render partial: "shared/paginator", locals: { pagy: @pagy } %></div>
    </div>
  </div>
</section>
