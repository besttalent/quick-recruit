<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class=" divide-y dark:divide-gray-700">
        <div class="panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Nurture Candidates</h1>
            <p class="text-muted-sm">Following <span class="font-bold"><%= @candidates.count %></span> candidates were added recently and needs to be nurtured.</p>
          </div>
          <a type="button" href="/candidates/new"
                class="btn-primary">
            Add new candidate
          </a>
        </div>
      </div>
      <div class="scroll-x">
        <table class="input-muted">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">Name</th>
              <th scope="col" class="px-4 py-3">Job Association</th>
              <th scope="col" class="table-head-cell">Owner</th>
              <th scope="col" class="table-head-cell">Added By</th>
              <th scope="col" class="table-head-cell">Added On</th>
              <th scope="col" class="table-head-cell">Duration</th>
              <th scope="col" class="table-head-cell">Last known status</th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "recent", collection: @candidates, as: :candidate %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
