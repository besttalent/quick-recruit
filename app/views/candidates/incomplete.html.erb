<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class=" divide-y dark:divide-gray-700">
        <div class="panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Incomplete Profiles</h1>
            <p class="text-muted-sm">Following <span class="font-bold"><%= @candidates.count %></span> profiles are not complete and either needs to be edited or some missing information is needed.</p>
          </div>
                   <div class="flex items-center space-x-4">
          <a type="button" href="/report/bucket_report?bucket=incomplete"
                class="btn-secondary">
            Candidate Report
          </a>

          <a type="button" href="/candidates/new"
                class="btn-primary">
            Add new candidate
          </a>
          </div>

        </div>
      </div>
      <div class="scroll-x">
        <table class="input-muted">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">Name</th>
              <th scope="col" class="px-4 py-3">Email</th>
              <th scope="col" class="px-4 py-3">Phone</th>
              <th scope="col" class="px-4 py-3">Primary Skill</th>
              <th scope="col" class="px-4 py-3">Job Association</th>
              <th scope="col" class="table-head-cell">Added By</th>
              <th scope="col" class="table-head-cell">Added On</th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "incomplete", collection: @candidates, as: :candidate %>
          </tbody>
        </table>
      </div>
      <div class="actions-row">
        <%== render partial: "shared/paginator", locals: { pagy: @pagy } %>
      </div>
    </div>
  </div>
</section>
