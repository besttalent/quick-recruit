<section class="page-surface">
  <div class="form-page-container">
    <h2 class="mb-4 text-2xl font-bold text-gray-900 dark:text-white">Add a new candidate</h2>

    <%= tailwind_form_with(model: @candidate, id: dom_id(@candidate), url: candidates_path) do |form| %>
      <%= render "shared/error_messages", resource: @candidate %>
      <%= render "shared/form_messages", resource: @candidate, message: local_assigns[:message] %>

      <div class="form-grid-simple">
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-900 dark:text-white" for="file_input">Upload Resume</label>
          <label class="block mb-2 text-xs text-gray-500 dark:text-white" for="file_input">Please upload PDF resume file only. PDF file size should be less than 5 MB.</label>

          <div class="items-center w-full sm:flex">
            <div class="w-full"><%= form.file_field :resume, accept: "application/pdf", required: true, id: "file_input" %></div>
          </div>

          <h2 class="mt-8 text-xl font-semibold leading-none text-gray-900 dark:text-white">Personal Information</h2>
        </div>

        <div><%= form.text_field :first_name, "First Name", required: true, placeholder: "John" %></div>

        <div class="w-full"><%= form.text_field :last_name, "Last Name", required: true, placeholder: "Doe" %></div>

        <div><%= form.text_field :email, "Email", required: true, placeholder: "name@domain.com" %></div>

        <div><%= form.text_field :phone, "Phone", required: true, placeholder: "9876543210" %></div>

        <div><%= form.text_field :location, "Current City", required: true, placeholder: "Noida" %></div>

        <div><%= form.text_field :birth_year, "Birth Year", placeholder: "1989" %></div>

        <div class="sm:col-span-2"><%= form.text_area :biography, "Biography", placeholder: "Some personal details about candidate..", style: "height:120px" %></div>
      </div>

      <h2 class="section-title">Professional Information</h2>

      <div class="form-grid-2">
        <div><%= form.text_field :current_title, "Current Job Title", placeholder: "Senior Software Engineer" %></div>

        <div><%= form.text_field :current_company, "Current Employer", placeholder: "Current Company Name" %></div>

        <div><%= form.text_field :current_ctc, "Current CTC (LPA)", placeholder: "12" %></div>

        <div><%= form.text_field :expected_ctc, "Expected CTC (LPA)", placeholder: "14" %></div>

        <div><%= form.text_field :experience, "Experience (Years)", placeholder: "5.2" %></div>

        <div><%= form.text_field :notice_period, "Notice Period (Days)", placeholder: "30" %></div>

        <div><%= form.text_field :highest_qualification, "Highest Education Qualification", placeholder: "B.Tech" %></div>

        <div>
          <label for="candidate_role_id" class="form-field-label-inline">
            Primary skill
            <button
              type="button"
              data-tooltip-target="tooltip-user-skill"
              data-tooltip-style="dark"
              class="ml-1"
            >
              <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>

              <span class="sr-only">Show information</span>
            </button>
            <%= tooltip_component(id: "tooltip-user-skill", text: "Select what is primary skill of this candidate.", class_name: "max-w-sm font-normal") %>
          </label>

          <%= form.collection_select(:role_id, @roles, :id, :title, { :prompt => "Select Primary Skill" }, :class => "form-text-field", :required => true) %>
        </div>
      </div>

      <h2 class="section-title">Social Information</h2>

      <div class="form-grid-2">
        <div><%= form.text_field :linkedin, "Linkedin", placeholder: "Linkedin Profile URL" %></div>

        <div><%= form.text_field :portfolio, "Personal Website or portfolio", placeholder: "Portfolio URL" %></div>

        <div><%= form.text_field :github, "Github", placeholder: "Github profile URL" %></div>

        <div><%= form.text_field :twitter, "Twitter", placeholder: "Twitter Profile" %></div>
      </div>

      <h2 class="section-title">Additional Information</h2>

      <div class="grid gap-4 md:gap-6 md:grid-cols-2 sm:mb-4">
        <div>
          <label for="candidate_source_id" class="form-field-label-inline-spaced">
            Candidate Source
            <button
              type="button"
              data-tooltip-target="tooltip-user-role"
              data-tooltip-style="dark"
              class="ml-1"
            >
              <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>

              <span class="sr-only">Show information</span>
            </button>
            <%= tooltip_component(id: "tooltip-user-role", text: "Please tell us from where this candidate was sourced or from where we got the resume.", class_name: "max-w-sm font-normal") %>
          </label>

          <%= form.collection_select(:source_id, @sources, :id, :title, { :prompt => "Select Source" }, :class => "form-text-field", :required => true) %>
        </div>

        <div>
          <label for="candidate_bucket" class="form-field-label-inline-spaced">
            Candidate Bucket
            <button
              type="button"
              data-tooltip-target="tooltip-user-bucket"
              data-tooltip-style="dark"
              class="ml-1"
            >
              <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>

              <span class="sr-only">Show information</span>
            </button>
            <%= tooltip_component(id: "tooltip-user-bucket", text: "In which bucket you want to put candidate.", class_name: "max-w-sm font-normal") %>
          </label>

          <%= select_tag :bucket, options_for_select(@buckets.map { |k, v| [k.humanize.capitalize, k] }), class: "form-text-field", :name => "candidate[bucket]", id: "candidate_bucket" %>
        </div>

        <div class="sm:col-span-2">
          <label for="candidate_opening_id" class="form-field-label-inline-spaced">
            Associate with Job Opening
            <button
              type="button"
              data-tooltip-target="tooltip-user-opening"
              data-tooltip-style="dark"
              class="ml-1"
            >
              <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>

              <span class="sr-only">Show information</span>
            </button>
            <%= tooltip_component(id: "tooltip-user-opening", text: "With which job opening you would like to Associate this candidate.", class_name: "max-w-sm font-normal") %>
          </label>

          <%= form.collection_select(:opening_id, @openings, :id, :title, { :prompt => "Select Job Opening to associate" }, :class => "form-text-field", :required => true) %>
        </div>

        <div class="sm:col-span-2"><%= form.text_area :note, "Additional Note", required: true, placeholder: "Add some additional note..", style: "height:120px" %></div>
      </div>

      <button type="submit" class="btn-primary">
        Add Candidate
      </button>

      <%= link_to "Cancel", :back, class: "btn-secondary" %>
    <% end %>
  </div>
</section>
