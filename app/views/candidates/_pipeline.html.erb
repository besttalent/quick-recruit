<tr class="group border-b border-gray-200 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700">
  <th scope="row" class=" px-4 py-2 font-medium text-gray-900 whitespace-nowrap dark:text-white">
    <div class="flex items-center hover:underline">
      <a href="<%= candidate_timeline_path(candidate) %>">
        <%= candidate.name %>
      </a>
      <a href="#" class="font-medium ml-2 invisible group-hover:visible text-primary-600 dark:text-primary-500 inline-flex items-center">
        <%= svg_icon("candidate-eye", class_name: "w-4 h-4 text-gray-800 dark:text-white") %>
      </a>
    </div>
  </th>
  <td class="px-4 py-2">
    <% if candidate.opening.active? %>
      <div class="flex items-center">
        <div class="w-3 h-3 mr-2 bg-green-500 border-green-500 rounded-full"></div>
        <span class="bg-<%= priority_color(candidate.opening.priority) %>-100 text-<%= priority_color(candidate.opening.priority) %>-800 text-xs font-medium me-2 px-1.5 py-0.5 rounded-sm border  border-<%= priority_color(candidate.opening.priority) %>-400"><%= candidate.opening.priority.titleize %></span>
        <%= candidate.opening.nil? ? "-" : candidate.opening.title %>
      </div>
    <% else %>
      <div class="flex items-center">
        <div class="w-3 h-3 mr-2 bg-red-500 border-red-500 rounded-full"></div>
        <span class="bg-<%= priority_color(candidate.opening.priority) %>-100 text-<%= priority_color(candidate.opening.priority) %>-800 text-xs font-medium me-2 px-1.5 py-0.5 rounded-sm border  border-<%= priority_color(candidate.opening.priority) %>-400"><%= candidate.opening.priority.titleize %></span>
        <%= candidate.opening.nil? ? "-" : candidate.opening.title %>
      </div>
    <% end %>
  </td>
  <td class="px-4 py-2"><%= candidate.owner.name %></td>
  <td class="px-4 py-2"><%= display_date(candidate.bucket_updated_on) %></td>
  <td class="px-4 py-2"><%= time_ago_in_words(candidate.bucket_updated_on) %></td>
  <td class="px-4 py-2">
    <span class="bg-<%= status_color(candidate.status) %>-100 text-<%= status_color(candidate.status) %>-800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm"><%= candidate.status.humanize.titleize %></span>
  </td>
</tr>
