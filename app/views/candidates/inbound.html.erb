<section class="bg-gray-50 dark:bg-gray-900 py-3 sm:py-5 min-h-screen">
  <div class="page-container-wide">
    <div class="page-card">
      <div class=" divide-y dark:divide-gray-700">
        <div class="panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Inbound Profiles</h1>
            <p class="text-muted-sm">Following <span class="font-bold"><%= @candidates.count %></span> profiles are sourced from Inbound channels.</p>
          </div>
          <div class="flex items-center space-x-4">
          <a type="button" href="/report/bucket_report?bucket=inbound"
                class="btn-secondary">
            Candidate Report
          </a>

          <a type="button" href="/candidates/new"
                class="btn-primary">
            Add new candidate
          </a>
          </div>
        </div>
      </div>
      <div class="scroll-x">
        <table class="input-muted">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-4 py-3">Name</th>
              <th scope="col" class="px-4 py-3">Job Association</th>
              <th scope="col" class="px-4 py-3 whitespace-nowrap">Owner</th>
              <th scope="col" class="px-4 py-3 whitespace-nowrap">Added By</th>
              <th scope="col" class="px-4 py-3 whitespace-nowrap">Added On</th>
              <th scope="col" class="px-4 py-3 whitespace-nowrap">Duration</th>
              <th scope="col" class="px-4 py-3 whitespace-nowrap">Last known status</th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "inbound", collection: @candidates, as: :candidate %>
          </tbody>
        </table>
      </div>
      <div class="actions-row">
        <%== render partial: "shared/paginator", locals: { pagy: @pagy } %>
      </div>
    </div>
  </div>
</section>
