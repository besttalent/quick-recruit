<div class="stack-fill">
  
  <div class="content-shell">
    
    <div class="sidebar-shell"><%= render partial: "candidate/profile", locals: { candidate: @candidate } %></div>

    <div class="flex-1">
      
      <%= render partial: "candidate/nav" %>
      <div class="timeline-list-wrap">
        <ol class="timeline-list-track">
          <% @events.each do |event| %>
            <%= render partial: "candidate/timeline/activity", locals: { event: event } %>
          <% end %>
        </ol>
      </div>
    </div>

    <div class="sidebar-panel">
      
      <div>
        <h5 class="panel-title">Quick Actions</h5>

        <p class="text-muted-sm-spaced">Select which actions you want to perform with this candidate.</p>

        <%= render partial: "candidate/status", locals: { candidate: @candidate } %>
        <%= render partial: "candidate/joining", locals: { candidate: @candidate } %>
        <%= render partial: "candidate/recycle", locals: { candidate: @candidate } %>
        <%= render partial: "candidate/lead", locals: { candidate: @candidate } %>
        <%= render partial: "candidate/recycle_date", locals: { candidate: @candidate } %>
      </div>
    </div>
  </div>
</div>
