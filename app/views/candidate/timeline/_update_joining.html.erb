<li class="timeline-item">
  <span class="timeline-node"><%= display_xsmall_avatar(event.user) %></span>
  <div class="timeline-toolbar-compact">
    <time class="timeline-meta-muted"><%= display_created_at_with_time(event) %></time>
    <div class="body-muted"><a href="<%= member_timeline_path(event.user) %>" class="link-strong-underline"><%= event.user.name %></a> updated candidate joining date to <%= display_date(event.eventable.joining_date) %>.</div>
  </div>
</li>
