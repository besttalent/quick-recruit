<li class="timeline-item">
  <span class="timeline-node">
    <%= display_xsmall_avatar(event.user) %>
  </span>
  <div class="toolbar-compact">
    <time class="timeline-meta-muted"><%= display_created_at_with_time(event) %></time>
    <div class="body-muted"><a href="<%= member_timeline_path(event.user) %>" class="link-strong-underline"><%= event.user.name %></a>  <span class="badge-primary-soft">rewarded candidate</span> to <a href="<%= member_timeline_path(event.trackable) %>" class="link-strong-underline"><%= event.trackable.name %></a></div>
  </div>
</li>
