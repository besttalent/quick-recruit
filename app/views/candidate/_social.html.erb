<% show_social = candidate.linkedin.present? or candidate.twitter.present? or candidate.github.present? or candidate.portfolio.present? %>

<% if show_social %>
  <dt class="mb-2 font-semibold leading-none text-gray-900 text-sm dark:text-white">Social</dt>
  <dd class="inline-flex items-center mb-4 sm:mb-5">
    <% if candidate.github.present? %>
      <a
        href="<%= candidate.github %>"
        target="_blank"
        data-tooltip-target="tooltip-github"
        class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
      >
        <%= svg_icon("github-logo", class_name: "w-5 h-5") %>
        <span class="sr-only">GitHub</span>
      </a>
      <div id="tooltip-github" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
        GitHub profile
        <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
    <% end %>

    <% if candidate.twitter.present? %>
      <a
        href="<%= candidate.twitter %>"
        target="_blank"
        data-tooltip-target="tooltip-twitter"
        class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
      >
        <%= svg_icon("twitter-logo", class_name: "w-5 h-5") %>
        <span class="sr-only">Twitter</span>
      </a>
      <div id="tooltip-twitter" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
        Twitter profile
        <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
    <% end %>

    <% if candidate.portfolio.present? %>
      <a
        href="<%= candidate.portfolio %>"
        target="_blank"
        data-tooltip-target="tooltip-portfolio"
        class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
      >
        <%= svg_icon("globe", class_name: "w-5 h-5") %>
        <span class="sr-only">Portfolio</span>
      </a>
      <div id="tooltip-portfolio" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
        Portfolio or Website
        <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
    <% end %>

    <% if candidate.linkedin.present? %>
      <a
        href="<%= absolute_url(candidate.linkedin) %>"
        target="_blank"
        data-tooltip-target="tooltip-linkedin"
        class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
      >
        <%= svg_icon("linkedin-logo", class_name: "w-5 h-5") %>
        <span class="sr-only">Linkedin</span>
      </a>
      <div id="tooltip-linkedin" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
        Linkedin profile
        <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
    <% end %>

    <% if candidate.respond_to?(:booking_url) && candidate.booking_url.present? %>
      <a
        href="<%= absolute_url(candidate.booking_url) %>"
        target="_blank"
        data-tooltip-target="tooltip-booking"
        class="p-1 text-gray-500 rounded-xs hover:text-gray-900 dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700"
      >
        <%= svg_icon("calendar-plus", class_name: "w-5 h-5") %>

        <span class="sr-only">Meeting Booking URL</span>
      </a>
      <div id="tooltip-booking" role="tooltip" class="inline-block text-xs absolute invisible z-10 py-1 px-2 text-xs font-medium text-white bg-gray-900 rounded-xs shadow-xs opacity-0 transition-opacity duration-300 tooltip dark:bg-gray-700">
        Meeting Booking URL
        <div class="tooltip-arrow" data-popper-arrow></div>
      </div>
    <% end %>
  </dd>
<% end %>
