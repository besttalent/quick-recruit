
<div class="sidebar-stack-fill">
  
  <div class="sidebar-content-shell">
    
    <div class="sidebar-shell">
      <%= render partial: "candidate/profile", locals: { candidate: @candidate } %>
    </div>
    <div class="flex-1">
      
      <%= render partial: "candidate/nav", locals: { candidate: @candidate } %>
      <div class="table-wrap">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-2">
                Sprint Name
              </th>
              <th scope="col" class="px-4 py-2">
                Date Range
              </th>
              <th scope="col" class="px-4 py-2">
                Owner
              </th>
              <th scope="col" class="px-4 py-2">
                Status
              </th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "campaign", collection: @campaigns, as: :campaign %>

          </tbody>
        </table>
      </div>
    </div>
    <div class="sidebar-panel">
      
      <% if policy(@candidate).update_campaign? %>
        <div>
          <h5 class="panel-title">Sprint</h5>
          <p class="text-muted-sm-spaced">Manage which sprint this candidate belongs to by selecting the correct sprint.</p>
          <%= render partial: "candidate/campaign", locals: { candidate: @candidate } %>

        </div>
      <% else %>
        <h5 class="panel-title mb-2">Sprint</h5>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">Candidates can be added to a sprint to track a sprint progress. </p>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">Although sprint for a candidate can be changed only when a candidate has been moved to pipeline bucket.</p>
        <p class="text-muted-sm-spaced">If you want to assign this candidate to any sprint, please ensure candidate is in pipeline bucket.</p>
      <% end %>
    </div>
  </div>
</div>
