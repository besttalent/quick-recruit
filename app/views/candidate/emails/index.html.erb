<div class="sidebar-stack-fill">
  <div class="sidebar-content-shell">
    <div class="sidebar-shell"><%= render partial: "candidate/profile", locals: { candidate: @candidate } %></div>

    <div class="flex-1">
      <%= render partial: "candidate/nav", locals: { candidate: @candidate } %>

      <div class="table-wrap">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-2">
                Email
              </th>

              <th scope="col" class="px-4 py-2">
                Sent By
              </th>

              <th scope="col" class="px-4 py-2">
                Sent On
              </th>

              <th scope="col" class="px-4 py-2">
                Status
              </th>

              <th scope="col" class="px-4 py-2">
                Action
              </th>
            </tr>
          </thead>

          <tbody id="emails" class="divide-y divide-gray-200"><%= render @emails %></tbody>
        </table>
      </div>
    </div>

    <div class="shrink-0 border-t border-gray-200 px-4 py-4 sm:px-6 lg:w-80 lg:border-l lg:border-t-0 lg:pr-8 xl:pr-6">
      <% if (!@candidate.opening.nil? and @candidate.opening.active?) or current_user.admin_or_recruiter_admin? %>
        <div>
          <h5 class="panel-title">Send Email</h5>

          <p class="text-muted-sm-spaced">Select which email you want to send to the candidate.</p>

          <% email_actions = [
            ["About Us & Job Description Email", "about_us_and_jd_email", "Are you sure you want to send Company Profile & JD email to this candidate?"],
            ["About Us Email", "about_us_email", "Are you sure you want to send Company Profile email to this candidate?"],
            ["Job Description Email", "job_description_email", "Are you sure you want to send Job Description email to this candidate?"],
            ["F2F Interview Details Email", "f2f_detail_email", "Are you sure you want to send details for Face to Face round to this candidate?"],
            ["Please send resume Email", "send_resume_email", "Are you sure you want to ask this candidate to send resume?"],
          ] %>

          <% email_actions.each do |title, kind, message| %>
            <%= confirm_action_button(title, candidate_emails_path(@candidate, kind: kind), message) %>
          <% end %>

          <% alert_email_actions = [
            ["Rejection Email", "rejection_email", "Are you sure you want to send rejection email to this candidate?"],
            ["Not A Match Email", "not_a_match_email", "Are you sure you want to send Not a Match email to this candidate?"],
            ["Sorry, Position Closed Email", "position_closed_email", "Are you sure you want to inform candidate that position has been closed?"],
          ] %>

          <% alert_email_actions.each do |title, kind, message| %>
            <%= confirm_action_button(title, candidate_emails_path(@candidate, kind: kind), message, "font-medium text-red-600 dark:text-red-500 hover:underline text-sm") %>
          <% end %>
        </div>
      <% else %>
        <div id="alert-additional-content-2" class="p-4 mb-4 text-red-800 border border-red-300 rounded-sm bg-red-50 dark:bg-gray-800 dark:text-red-400 dark:border-red-800" role="alert">
          <div class="flex items-center">
            <%= svg_icon("info-circle", class_name: "flex-shrink-0 w-4 h-4 me-2") %>

            <span class="sr-only">Info</span>

            <h3 class="text-md font-medium">Unable to send emails</h3>
          </div>

          <div class="mt-2 mb-4 text-sm">
            Either the candidate is not associcated with any opening or the opening is not active. Please check the candidate's profile and try again.
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
