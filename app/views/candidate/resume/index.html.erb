<!--
  This example requires updating your template:

  ```
  <html class="h-full bg-white">
  <body class="h-full">
  ```
-->

<div class="stack-fill">
  <!-- 3 column wrapper -->
  <div class="content-shell">
    <!-- Left sidebar & main wrapper -->
    <div class="sidebar-shell"><%= render partial: "candidate/profile", locals: { candidate: @candidate } %></div>

    <div class="flex-1">
      <!-- Main area -->
      <%= render partial: "candidate/nav", locals: { candidate: @candidate } %>
      <div class="px-0">
        <iframe
          src="https://www.crownstack.com/pdfs/cs-mission-and-vision-statement.pdf"
          width="780"
          height="780"
          style="border: none;"
          title="Crownstack Mission and Vision Statement"
        ></iframe>
      </div>
    </div>

    <div class="shrink-0 border-t border-gray-200 px-4 py-6 sm:px-6 lg:w-80 lg:border-l lg:border-t-0 lg:pr-8 xl:pr-6">
      <!-- Right column area -->
    </div>
  </div>
</div>
