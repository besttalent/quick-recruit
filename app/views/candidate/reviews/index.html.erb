<div class="stack-fill">
  <div class="content-shell">
    <div class="sidebar-shell">
      <%= render partial: "candidate/profile", locals: { candidate: @candidate } %>
    </div>

    <div class="flex-1">
      <%= render partial: "candidate/nav", locals: { candidate: @candidate } %>

      <form class="p-4">
        <div class="w-full mb-4 border border-gray-200 rounded-xs bg-gray-50 dark:bg-gray-700 dark:border-gray-600">
          <div class="px-4 py-2 bg-white rounded-t-lg dark:bg-gray-800">
            <label for="comment" class="sr-only">Your comment</label>

            <textarea
              id="comment"
              rows="4"
              class="textarea-plain"
              placeholder="Add a review..."
              required
            ></textarea>
          </div>

          <div class="flex items-right justify-end px-3 py-2 border-t border-gray-200 dark:border-gray-600">
            <div class="flex items-center mr-4">
              <%= svg_icon("star-solid", class_name: "w-4 h-4 text-yellow-300 ms-1") %>
              <%= svg_icon("star-solid", class_name: "w-4 h-4 text-yellow-300 ms-1") %>
              <%= svg_icon("star-solid", class_name: "w-4 h-4 text-yellow-300 ms-1") %>
              <%= svg_icon("star-solid", class_name: "w-4 h-4 text-yellow-300 ms-1") %>
              <%= svg_icon("star-solid", class_name: "w-4 h-4 ms-1 text-gray-300 dark:text-gray-500") %>
            </div>

            <button type="submit" class="btn-primary">
              Add Review
            </button>
          </div>
        </div>
      </form>

      <div class="px-4 py-6 sm:px-6">
        <ul role="list" class="space-y-8">
          <li>
            <div class="flex space-x-3">
              <div class="flex-shrink-0">
                <%= image_tag "male-placeholder.png", class: "h-10 w-10 rounded-full", alt: "" %>
              </div>

              <div>
                <div class="text-sm">
                  <button type="button" class="font-medium text-gray-900">Leslie Alexander</button>
                </div>

                <div class="mt-1 text-sm text-gray-700">
                  <p>Ducimus quas delectus ad maxime totam doloribus reiciendis ex. Tempore dolorem maiores. Similique voluptatibus tempore non ut.</p>
                </div>

                <div class="mt-2 space-x-2 text-sm">
                  <span class="caption-muted">4d ago</span>
                  <span class="caption-muted">&middot;</span>

                  <button type="button" class="font-medium text-gray-900">Reply</button>
                </div>
              </div>
            </div>
          </li>

          <li>
            <div class="flex space-x-3">
              <div class="flex-shrink-0">
                <%= image_tag "male-placeholder.png", class: "h-10 w-10 rounded-full", alt: "" %>
              </div>

              <div>
                <div class="text-sm">
                  <button type="button" class="font-medium text-gray-900">Michael Foster</button>
                </div>

                <div class="mt-1 text-sm text-gray-700">
                  <p>Et ut autem. Voluptatem eum dolores sint necessitatibus quos. Quis eum qui dolorem accusantium voluptas voluptatem ipsum. Quo facere iusto quia accusamus veniam id explicabo et aut.</p>
                </div>

                <div class="mt-2 space-x-2 text-sm">
                  <span class="caption-muted">4d ago</span>
                  <span class="caption-muted">&middot;</span>

                  <button type="button" class="font-medium text-gray-900">Reply</button>
                </div>
              </div>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <div class="sidebar-panel"></div>
  </div>
</div>
