<tr class="group hover-list-row">
  <th scope="row" class="table-cell-strong">
    <div class="inline-link-row">
      <a href="<%= candidate_timeline_path(candidate) %>">
        <%= candidate.name %>
      </a>
      <button class="hover-reveal-link">
        <%= svg_icon("candidate-eye", class_name: "w-4 h-4 text-gray-800 dark:text-white") %>
      </button>
    </div>
  </th>
  <td class="px-4 py-2">
    <%= candidate.opening.nil? ? "-" : candidate.opening.title %>
  </td>
  <td class="px-4 py-2"><%= candidate.user.name %></td>
  <td class="px-4 py-2"><%= candidate.owner.name %></td>
  <td class="px-4 py-2"><%= display_date(candidate.updated_at) %></td>
  <td class="px-4 py-2">
    <span class="badge-primary-soft">
      <%= candidate.bucket.titleize %>
    </span>
  </td>
  <td class="px-4 py-2">
    <span class="bg-<%= status_color(candidate.status) %>-100 text-<%= status_color(candidate.status) %>-800 text-xs font-medium inline-flex items-center px-2 py-0.5 rounded-sm"><%= candidate.status.humanize.titleize %></span>
  </td>
</tr>
