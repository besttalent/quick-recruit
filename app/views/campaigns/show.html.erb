<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class="sidebar-list-divider">
        <div class="page-panel-header-row">
          <div>
            <h1 class="heading-lg-soft"><%= @campaign.name %></h1>
            <p class="text-muted-sm">Following <span class="font-bold"><%= @candidates.count %></span> candidates are currently in this sprint under various stages.</p>
          </div>
          <% if @campaign.active? %>
          <div class="flex space-x-2">
          <%= link_to "Edit Sprint", edit_campaign_path(@campaign), class: "btn-secondary" %>
            <%= button_to "Close Sprint", close_campaign_path(@campaign), class: "btn-primary", data: {
                                                                            controller: "confirmation",
                                                                            "confirmation-message-value": "Are you sure you want to close this sprint?",
                                                                            action: "confirmation#confirm",
                                                                            turbo_method: :patch,
                                                                          } %>
                                                                                    </div>

          <% end %>
        </div>
      </div>

      <div class="sidebar-scroll-x">
        <div class="font-medium whitespace-nowrap w-full"><%= render partial: "progress", locals: { campaign: @campaign } %></div>
        <table class="input-muted">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">Name</th>
              <th scope="col" class="px-4 py-3">Job Association</th>
              <th scope="col" class="table-head-cell">Owner</th>
              <th scope="col" class="table-head-cell">Last Updated On</th>
              <th scope="col" class="table-head-cell">Bucket</th>
              <th scope="col" class="table-head-cell">Last known Status</th>
            </tr>
          </thead>
          <tbody><%= render partial: "candidate", collection: @candidates, as: :candidate %></tbody>
        </table>
      </div>
    </div>
  </div>
</section>
