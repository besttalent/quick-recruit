<section class="page-surface">
  <div class="page-form-container">
    <%= render "shared/form_messages", resource: @form, message: local_assigns[:message] %>
    <%= render "shared/form_header", title: "Add New Sprint", subtitle: "Please fill in details of new sprint." %>

    <%= tailwind_form_with(model: @campaign, id: dom_id(@campaign), url: campaigns_path, method: "POST") do |form| %>
      <div class="grid-block-spaced">
        <div>
          <%= form.text_field :name, "Sprint Name", required: true, placeholder: "e.g. Team Lead Hiring Sprint" %>
        </div>
      </div>

      <div class="form-grid-simple">
        <div class="sm:col-span-2 space-y-2">
          <div>
            <label for="campaign_owner_id" class="form-field-label-inline"> Owner </label>
            <%= form.collection_select(:owner_id, @owners, :id, :name, { :prompt => "Select Owner" }, :class => "form-text-field", :required => true) %>
          </div>
        </div>
      </div>

      <div class="mt-4 grid gap-4 sm:grid-cols-2 sm:gap-6">
        <div>
          <label for="campaign_start_date" class="form-field-label-inline"> Start Date </label>
          <%= form.date_field :start_date, class: "form-text-field" %>
        </div>

        <div>
          <label for="campaign_end_date" class="form-field-label-inline"> End Date </label>
          <%= form.date_field :end_date, class: "form-text-field" %>
        </div>
      </div>

      <button type="submit" class="btn-primary mt-4">
        Add New Sprint
      </button>

      <%= link_to "Cancel", :back, class: "btn-secondary" %>
    <% end %>
  </div>
</section>
