<section class="page-bg-shell">
  <div class="page-container-wide">
    <div class="page-card">
      <div class="sidebar-list-divider">
        <div class="page-panel-header-row">
          <div>
            <h1 class="heading-lg-soft">Recruitment Team</h1>
            <p class="text-muted-sm">Manage all your existing team members or add a new one.</p>
          </div>

          <div class="flex items-center space-x-2">
            <a
              type="button"
              target="_blank"
              href="/public/team"
              class="btn-secondary"
            >
              Show Public Page
            </a>

            <a type="button" href="/members/new" class="btn-primary"> Add new member </a>
          </div>
        </div>
      </div>

      <div class="sidebar-scroll-x">
        <table class="input-muted">
          <thead class="table-head-muted">
            <tr>
              <th scope="col" class="px-4 py-3">User</th>
              <th scope="col" class="px-4 py-3">User Role</th>
              <th scope="col" class="px-4 py-3">Position</th>
              <th scope="col" class="px-4 py-3">Email</th>
              <th scope="col" class="px-4 py-3">Phone</th>
              <th scope="col" class="px-4 py-3">Status</th>
              <th scope="col" class="table-head-cell">Last Login</th>
              <th scope="col" class="table-head-cell">Added On</th>
            </tr>
          </thead>

          <tbody><%= render partial: "member", collection: @members, as: :member %></tbody>
        </table>
      </div>
    </div>
  </div>
</section>
