<%= tailwind_form_with(model: member, id: dom_id(member), url: member_path(member)) do |form| %>
  <%= render "shared/error_messages", resource: member %>
  <%= render "shared/form_messages", resource: member, message: local_assigns[:message] %>

  <h2 class="section-title">Personal Information</h2>

  <div class="form-grid-simple">
    <div><%= form.text_field :first_name, "First Name", required: true, placeholder: "John" %></div>

    <div class="w-full"><%= form.text_field :last_name, "Last Name", required: true, placeholder: "Doe" %></div>

    <div><%= form.text_field :email, "Email", required: true, placeholder: "name@domain.com" %></div>

    <div><%= form.text_field :phone, "Phone", required: true, placeholder: "9876543210" %></div>

    <div><%= form.text_field :location, "Current City", required: true, placeholder: "Noida" %></div>

    <div class="sm:col-span-2"><%= form.text_area :biography, "Biography", required: true, placeholder: "Tell us about yourself..", style: "height:120px" %></div>
  </div>

  <h2 class="section-title">Social Information</h2>

  <div class="form-grid-2">
    <div><%= form.text_field :linkedin, "Linkedin", placeholder: "Linkedin Profile URL" %></div>

    <div><%= form.text_field :portfolio, "Portfolio Or Resume Link", placeholder: "Portfolio or resume URL" %></div>

    <div><%= form.text_field :github, "Github", placeholder: "Github profile URL" %></div>

    <div><%= form.text_field :twitter, "Twitter", placeholder: "Twitter Profile" %></div>

    <div><%= form.text_field :website, "Personal Website", placeholder: "Personal Website URL" %></div>

    <div><%= form.text_field :booking_url, "Meeting Booking URL", placeholder: "Meeting Booking URL" %></div>
  </div>

  <h2 class="section-title">Professional Information</h2>

  <div class="form-grid-2">
    <div><%= form.text_field :current_title, "Current Job Title", placeholder: "Senior Software Engineer" %></div>
    <div><%= form.text_field :current_company, "Current Employer", placeholder: "Current Company Name" %></div>
  </div>

  <h2 class="section-title">Admin Land</h2>

  <div class="form-grid-2">
    <div>
      <label for="user_role" class="field-label-inline-spaced">
        User Role
        <button
          type="button"
          data-tooltip-target="tooltip-user-role"
          data-tooltip-style="dark"
          class="ml-1"
        >
          <%= svg_icon("info-circle", class_name: "w-4 h-4 text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-gray-500") %>

          <span class="sr-only">Show information</span>
        </button>
        <%= tooltip_component(id: "tooltip-user-role", text: "A team member can be either data collector, recruiter, interviewer, admin, recruiter admin or super admin.", class_name: "max-w-sm font-normal") %>
      </label>

      <%= select_tag :role, options_for_select(User.roles.map { |k, v| [k.humanize.titleize, k] }, member.role), class: "form-text-field", :name => "user[role]", id: "user_role" %>
    </div>

    <div><label for="user_active" class="field-label-inline">Select if Active</label><%= form.select(:active, [["Active", true], ["Inactive", false]], {}, :class => "form-text-field") %></div>
  </div>

  <button type="submit" class="btn-primary">
    Update Information
  </button>

  <%= link_to "Cancel", :back, class: "btn-secondary" %>
<% end %>
